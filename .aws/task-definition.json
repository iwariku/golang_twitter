{
  "containerDefinitions": [
    {
      "name": "x-clone",
      "image": "<image uri>",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp",
          "name": "x-clone-8080-tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "SMTP_PORT",
          "value": "587"
        },
        {
          "name": "FRONT_APP_URL",
          "value": "https://twitter-nextjs-frontend.vercel.app"
        },
        {
          "name": "REDIS_ADDRESS",
          "value": "master.x-clone-redis-node.va01tw.apne1.cache.amazonaws.com:6379"
        },
        {
          "name": "FROM_EMAIL",
          "value": "noreply@x-clone.org"
        },
        {
          "name": "SMTP_HOST",
          "value": "email-smtp.ap-northeast-1.amazonaws.com"
        }
      ],
      "environmentFiles": [],
      "mountPoints": [],
      "volumesFrom": [],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:577638382521:secret:x-clone/prod/rds-3i2OsK:DATABASE_URL::"
        },
        {
          "name": "SMTP_PASS",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:577638382521:secret:x-clone/prod/smtp-lvLY5N:SMTP_PASS::"
        },
        {
          "name": "SMTP_USER",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:577638382521:secret:x-clone/prod/smtp-lvLY5N:SMTP_USER::"
        }
      ],
      "ulimits": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/x-clone-task",
          "awslogs-create-group": "true",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "ecs"
        },
        "secretOptions": []
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f -s -o /dev/null http://localhost:8080/health_check || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      },
      "systemControls": []
    }
  ],
  "family": "x-clone-task",
  "taskRoleArn": "arn:aws:iam::577638382521:role/xCloneTaskS3ReadWriteRole",
  "executionRoleArn": "arn:aws:iam::577638382521:role/xCloneTaskExecutionRole",
  "networkMode": "awsvpc",
  "volumes": [],
  "placementConstraints": [],
  "runtimePlatform": {
    "cpuArchitecture": "ARM64",
    "operatingSystemFamily": "LINUX"
  },
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024"
}
